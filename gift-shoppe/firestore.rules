rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core function to check if the user is authenticated at all
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users Collection
    // Users can only read and update their own document.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      // Anyone can create an account if they are authenticated via Firebase Auth
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Wishlist subcollection — per-user saved products
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Products Collection
    // Anyone (even unauthenticated guests) can view the products catalog.
    // However, NO ONE can write to the products collection from the client app.
    // (Product creation/updating MUST be done securely via the Firebase Console or an Admin SDK backend).
    match /products/{productId} {
      allow read: if true;
      allow write: if false; 
    }

    // 3. Orders Collection
    // Users can only view or create orders attached to their own UID.
    match /orders/{orderId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // When creating an order, explicitly check that the payload's userId matches the token
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Editing an order from the client app is typically disabled to prevent tampering post-purchase
      allow update, delete: if false; 
    }

    // 4. Cart Collection (If you store cart instances in Firestore instead of localStorage)
    match /carts/{cartId} {
      allow read, write: if isOwner(cartId);
    }
    
    // Default Deny for anything we forgot
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
