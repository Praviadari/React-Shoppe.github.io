# Public site URL for canonical links, Open Graph, and sitemap generation
REACT_APP_SITE_URL=https://your-username.github.io/gift-shoppe

# Firebase (Phase 3+) — copy to .env.local for local development
# Enable Email/Password sign-in in Firebase Console → Authentication → Sign-in method
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Optional error monitoring (production only when DSN is set)
REACT_APP_SENTRY_DSN=

# Comma-separated admin emails for /admin dashboard access
REACT_APP_ADMIN_EMAILS=
