{
  "name": "gift-shoppe",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "dompurify": "^3.3.3",
    "firebase": "^11.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.27.1",
    "@remix-run/router": "^1.23.2",
    "@tootallnate/once": "^3.0.0",
    "flatted": "^3.3.3",
    "form-data": "^4.0.4",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "minimatch": "^9.0.5",
    "test-exclude": {
      "minimatch": "^3.1.2"
    },
    "glob": {
      "minimatch": "^3.1.2"
    },
    "nth-check": "^2.1.1",
    "path-to-regexp": "^6.3.0",
    "postcss": "^8.5.3",
    "protobufjs": "^7.4.0",
    "semver": "^7.7.1",
    "serialize-javascript": "^7.0.5",
    "shell-quote": "^1.8.2",
    "underscore": "^1.13.8",
    "undici": "^7.2.0",
    "uuid": "^11.1.0",
    "webpack-dev-server": "^5.2.5",
    "ws": "^8.18.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "build": "npm run generate:sitemap && npm run generate:webp && react-scripts build && npm run prerender",
    "prerender": "node scripts/prerender-static.js",
    "lhci": "lhci autorun",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:webp": "node scripts/generate-webp.js",
    "sync:catalog-prices": "node scripts/generate-catalog-prices.js",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --coverage --forceExit",
    "eject": "react-scripts eject",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:ci": "start-server-and-test \"serve -s build -l 3000\" http://localhost:3000 cy:run",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "npm run sync:catalog-prices && firebase deploy --only functions"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/reportWebVitals.js",
      "!src/**/*.test.js",
      "!src/app/routes.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 19,
        "branches": 12,
        "functions": 18,
        "lines": 20
      },
      "./src/utils/": {
        "statements": 70,
        "branches": 55,
        "functions": 70,
        "lines": 70
      },
      "./src/services/orderService.js": {
        "statements": 50,
        "branches": 35,
        "functions": 50,
        "lines": 50
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "cypress": "^13.15.2",
    "cypress-axe": "^1.6.0",
    "axe-core": "^4.10.3",
    "gh-pages": "^6.1.1",
    "sharp": "^0.33.5",
    "@lhci/cli": "^0.14.0",
    "serve": "^14.2.4",
    "start-server-and-test": "^2.0.12",
    "tailwindcss": "^3.3.1"
  }
}
